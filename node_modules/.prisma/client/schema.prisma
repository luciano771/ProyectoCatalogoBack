generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MERCHANT
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  DELIVERED
}

enum PaymentProvider {
  MERCADO_PAGO
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  role     UserRole @default(MERCHANT)

  merchantProfile MerchantProfile?
  errorLogs       ErrorLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model MerchantProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  businessName    String
  slug            String  @unique
  description     String?
  logoUrl         String?
  bannerUrl       String?
  instagramUrl    String?
  paymentAlias    String?
  active          Boolean @default(true)
  backgroundColor String?
  themeId         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  categories  Category[]
  products    Product[]
  orders      Order[]
  carts       Cart[]
  bulkImports BulkImport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Category {
  id                String  @id @default(cuid())
  merchantProfileId String
  name              String
  slug              String
  isActive          Boolean @default(true)
  sortOrder         Int?

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  products        Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([merchantProfileId, slug])
  @@index([merchantProfileId])
}

model Product {
  id                String  @id @default(cuid())
  merchantProfileId String
  categoryId        String?
  name              String
  marca             String?
  modelo            String?
  description       String?
  price             Decimal @db.Decimal(10, 2)
  imageCoverUrl     String?
  stock             Int?
  active            Boolean @default(true)

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  category        Category?       @relation(fields: [categoryId], references: [id])
  images          ProductImage[]

  orderItems OrderItem[]
  cartItems  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merchantProfileId])
  @@index([categoryId])
  @@index([merchantProfileId, active])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model Order {
  id                String @id @default(cuid())
  merchantProfileId String

  buyerName   String
  buyerPhone  String
  buyerEmail  String?
  totalAmount Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  payments        Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merchantProfileId, status])
  @@index([createdAt])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String

  productName String
  unitPrice   Decimal @db.Decimal(10, 2)
  quantity    Int
  subtotal    Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id      String @id @default(cuid())
  orderId String

  provider          PaymentProvider
  providerPaymentId String
  status            PaymentStatus
  amount            Decimal         @db.Decimal(10, 2)
  rawResponse       Json?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([provider, providerPaymentId])
  @@index([status])
}

model Cart {
  id                String   @id @default(cuid())
  visitorId         String
  merchantProfileId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)
  items           CartItem[]

  @@unique([visitorId, merchantProfileId])
  @@index([visitorId])
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  productId String
  quantity  Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
}

model BulkImport {
  id                String   @id @default(cuid())
  merchantProfileId String
  fileName          String
  fileSize          Int?
  fileContent       Bytes?
  rowsTotal         Int
  rowsCreated       Int
  errorsJson        Json?
  createdAt         DateTime @default(now())

  merchantProfile MerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)

  @@index([merchantProfileId])
  @@index([createdAt])
}

model ErrorLog {
  id        String   @id @default(cuid())
  key       String
  component String
  message   String   @db.Text
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([key])
  @@index([userId])
}
